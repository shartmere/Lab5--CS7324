def get_embedding_dim(vocab_size):
    return min(50, (vocab_size // 2) + 1)

def build_wide_deep_model(deep_layers, dropout_rate=0.3, learning_rate=1e-3):
   
    # Inputs
    num_input = keras.Input(shape=(len(num_cols),), name='num_input')
    
    cat_inputs = {}
    for col in cat_cols:
        cat_inputs[col] = keras.Input(shape=(1,), dtype='int32', name=col)
    
    cross_inputs = {}
    for cross_name in cross_features:
        cross_inputs[cross_name] = keras.Input(shape=(1,), dtype='int32', name=cross_name)
    
    #  Deep Branch
    cat_embeddings = []
    for col in cat_cols:
        vocab = cat_vocab_sizes[col]
        emb_dim = get_embedding_dim(vocab)
        emb = layers.Embedding(input_dim=vocab, output_dim=emb_dim, name=f'emb_{col}')(cat_inputs[col])
        emb = layers.Flatten()(emb)
        cat_embeddings.append(emb)
    
    
    deep_input = layers.Concatenate()([num_input] + cat_embeddings)
    deep_out = deep_input
    
    for units in deep_layers:
        deep_out = layers.Dense(units, activation='relu')(deep_out)
        deep_out = layers.BatchNormalization()(deep_out)
        deep_out = layers.Dropout(dropout_rate)(deep_out)
    
    #Wide Branch
    
    cross_embeddings = []
    for cross_name in cross_features:
        vocab = cross_vocab_sizes[cross_name]
        emb = layers.Embedding(input_dim=vocab, output_dim=1, name=f'emb_{cross_name}')(cross_inputs[cross_name])
        emb = layers.Flatten()(emb)
        cross_embeddings.append(emb)
    
    
    wide_out = layers.Concatenate()([num_input] + cross_embeddings)
    
    
    combined = layers.Concatenate()([wide_out, deep_out])
    output = layers.Dense(1, activation='sigmoid', name='output')(combined)
    
    # Build Model 
    all_inputs = [num_input] + list(cat_inputs.values()) + list(cross_inputs.values())
    model = Model(inputs=all_inputs, outputs=output)
    
    model.compile(
        optimizer=keras.optimizers.Adam(learning_rate=learning_rate),
        loss='binary_crossentropy',
        metrics=['AUC']
    )
    
    return model

