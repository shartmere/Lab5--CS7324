def build_mlp_model(deep_layers, dropout_rate=0.3, learning_rate=1e-3):
    num_input = keras.Input(shape=(len(num_cols),), name='num_input')
    
    cat_inputs = {}
    for col in cat_cols:
        cat_inputs[col] = keras.Input(shape=(1,), dtype='int32', name=col)
    
    cat_embeddings = []
    for col in cat_cols:
        vocab = cat_vocab_sizes[col]
        emb_dim = get_embedding_dim(vocab)
        emb = layers.Embedding(input_dim=vocab, output_dim=emb_dim, name=f'emb_{col}')(cat_inputs[col])
        emb = layers.Flatten()(emb)
        cat_embeddings.append(emb)
    
    deep_out = layers.Concatenate()([num_input] + cat_embeddings)
    
    for units in deep_layers:
        deep_out = layers.Dense(units, activation='relu')(deep_out)
        deep_out = layers.BatchNormalization()(deep_out)
        deep_out = layers.Dropout(dropout_rate)(deep_out)
    
    output = layers.Dense(1, activation='sigmoid', name='output')(deep_out)
    
    all_inputs = [num_input] + list(cat_inputs.values())
    model = Model(inputs=all_inputs, outputs=output)
    model.compile(
        optimizer=keras.optimizers.Adam(learning_rate=learning_rate),
        loss='binary_crossentropy',
        metrics=['AUC']
    )
    return model

